<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyNotesApp.MainPage"
             Title="Главная">
  <ScrollView>
    <VerticalStackLayout Padding="24" Spacing="18">
      <Border Padding="22" BackgroundColor="{AppThemeBinding Light={StaticResource LightSurfaceColor}, Dark={StaticResource DarkSurfaceColor}}">
        <VerticalStackLayout Spacing="16" HorizontalOptions="Center">
          <Border WidthRequest="92" HeightRequest="92" StrokeThickness="0" BackgroundColor="{StaticResource AccentColor}">
            <Border.StrokeShape>
              <RoundRectangle CornerRadius="28" />
            </Border.StrokeShape>
            <Label Text="✦" FontSize="44" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
          </Border>
          <Label x:Name="TitleLabel" Text="Задачник и Заметки" FontSize="30" FontAttributes="Bold" HorizontalTextAlignment="Center" Opacity="0" />
          <Label Text="Быстрый доступ к заметкам и задачам. Разделы оформлены карточками — позже сюда можно добавить новые модули." Style="{StaticResource MutedLabelStyle}" HorizontalTextAlignment="Center" />
        </VerticalStackLayout>
      </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                <Border Grid.Column="0" Padding="20" StrokeShape="RoundRectangle 18">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnNotesClicked"/>
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center" VerticalOptions="Center">
                        <Image Source="notes.svg" WidthRequest="60" HeightRequest="60" HorizontalOptions="Center"/>
                        <Label Text="Заметки" FontSize="18" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="1" Padding="20" StrokeShape="RoundRectangle 18">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTasksClicked"/>
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center" VerticalOptions="Center">
                        <Image Source="tasks.svg" WidthRequest="60" HeightRequest="60" HorizontalOptions="Center"/>
                        <Label Text="Задачник" FontSize="18" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>

            </Grid>

            <Border Padding="18">
        <VerticalStackLayout Spacing="10">
          <Label Text="Режим оформления" FontSize="20" FontAttributes="Bold" />
          <Label Text="Выберите светлый, темный или системный режим." Style="{StaticResource MutedLabelStyle}" />
          <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
            <Button Text="Светлый" Clicked="OnLightThemeClicked" Style="{StaticResource GhostButtonStyle}" />
            <Button Grid.Column="1" Text="Темный" Clicked="OnDarkThemeClicked" Style="{StaticResource GhostButtonStyle}" />
            <Button Grid.Column="2" Text="Система" Clicked="OnSystemThemeClicked" Style="{StaticResource GhostButtonStyle}" />
          </Grid>
        </VerticalStackLayout>
      </Border>
    </VerticalStackLayout>
  </ScrollView>
</ContentPage>
