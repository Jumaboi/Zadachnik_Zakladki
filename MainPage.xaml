<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyNotesApp.MainPage"
             Title="Главная"
             BackgroundColor="White">
  <ContentPage.Content>
    <VerticalStackLayout Padding="24" Spacing="18" VerticalOptions="Center">
      <Label x:Name="TitleLabel" Text="MyNotes" FontSize="32" HorizontalOptions="Center" TextColor="#0B2545" Opacity="0"/>
      <Button Text="Заметки" Clicked="OnNotesClicked" BackgroundColor="#5B2EE6" TextColor="White" HeightRequest="48"/>
      <Button Text="Задачник" Clicked="OnTasksClicked" BackgroundColor="#0B2545" TextColor="White" HeightRequest="48"/>
    </VerticalStackLayout>
  </ContentPage.Content>
</ContentPage>
