<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyNotesApp.MainPage"
             Title="Главная"
             BackgroundColor="{AppThemeBinding Light={StaticResource LightBackground}, Dark={StaticResource DarkBackground}}">

    <ScrollView>

        <VerticalStackLayout Padding="24" Spacing="18">

            <!-- HEADER -->
            <Border Padding="22"
                    Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource DarkBorder}}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource DarkSurface}}"
                    StrokeShape="RoundRectangle 18">

                <VerticalStackLayout Spacing="16" HorizontalOptions="Center">

                    <Border WidthRequest="92"
                            HeightRequest="92"
                            StrokeThickness="0"
                            BackgroundColor="#6D5DF6"
                            StrokeShape="RoundRectangle 28">

                        <Label Text="✦"
                               FontSize="44"
                               TextColor="White"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>

                    <Label x:Name="TitleLabel"
                           Text="Задачник и Заметки"
                           FontSize="30"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center"
                           Opacity="0"/>

                    <Label Text="Быстрый доступ к заметкам и задачам. Разделы оформлены карточками — позже сюда можно добавить новые модули."
                           TextColor="{AppThemeBinding Light=#64748B, Dark=#CBD5E1}"
                           HorizontalTextAlignment="Center"/>

                </VerticalStackLayout>
            </Border>

            <!-- CARDS -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="14">

                <Border Grid.Column="0"
                        Padding="20"
                        Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource DarkBorder}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource DarkSurface}}"
                        StrokeShape="RoundRectangle 18">

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnNotesClicked"/>
                    </Border.GestureRecognizers>

                    <VerticalStackLayout Spacing="10"
                                         HorizontalOptions="Center"
                                         VerticalOptions="Center">

                        <Image Source="notes.svg"
                               WidthRequest="60"
                               HeightRequest="60"/>

                        <Label Text="Заметки"
                               FontSize="18"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1"
                        Padding="20"
                        Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource DarkBorder}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource DarkSurface}}"
                        StrokeShape="RoundRectangle 18">

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTasksClicked"/>
                    </Border.GestureRecognizers>

                    <VerticalStackLayout Spacing="10"
                                         HorizontalOptions="Center"
                                         VerticalOptions="Center">

                        <Image Source="tasks.svg"
                               WidthRequest="60"
                               HeightRequest="60"/>

                        <Label Text="Задачник"
                               FontSize="18"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>

            </Grid>

            <!-- THEME -->
            <Border Padding="18"
                    Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource DarkBorder}}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource DarkSurface}}"
                    StrokeShape="RoundRectangle 18">

                <VerticalStackLayout Spacing="10">

                    <Label Text="Режим оформления"
                           FontSize="20"
                           FontAttributes="Bold"/>

                    <Label Text="Выберите светлый, темный или системный режим."
                           TextColor="{AppThemeBinding Light=#64748B, Dark=#CBD5E1}"/>

                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">

                        <Button Text="Светлый"
                                Clicked="OnLightThemeClicked"/>

                        <Button Text="Темный"
                                Grid.Column="1"
                                Clicked="OnDarkThemeClicked"/>

                        <Button Text="Система"
                                Grid.Column="2"
                                Clicked="OnSystemThemeClicked"/>

                    </Grid>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>

    </ScrollView>
</ContentPage>