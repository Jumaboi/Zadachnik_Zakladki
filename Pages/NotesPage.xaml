<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MyNotesApp.ViewModels"
             x:Class="MyNotesApp.Pages.NotesPage"
             Title="Заметки">
  <ContentPage.BindingContext>
    <vm:NotesViewModel />
  </ContentPage.BindingContext>

  <Grid>
    <ScrollView>
      <VerticalStackLayout Padding="18" Spacing="16">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
          <Button Text="‹" Clicked="OnBackClicked" Style="{StaticResource TopIconButtonStyle}" />
          <VerticalStackLayout Grid.Column="1" Spacing="2">
            <Label Text="Заметки" FontSize="28" FontAttributes="Bold" />
            <Label x:Name="NotesModeLabel" Text="Активные заметки" Style="{StaticResource MutedLabelStyle}" />
          </VerticalStackLayout>
          <Button Grid.Column="2" Text="☾" Clicked="OnToggleThemeClicked" Style="{StaticResource TopIconButtonStyle}" />
          <Button Grid.Column="3" Text="⋯" Clicked="OnOpenMenuClicked" Style="{StaticResource TopIconButtonStyle}" />
        </Grid>

        <Border Padding="18">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <Label Text="Создавайте заметки через отдельное окно. Чек-листы можно отмечать прямо в карточке." Style="{StaticResource MutedLabelStyle}" />
            <Button Grid.Column="1" Text="＋" FontSize="24" Clicked="OnOpenAddNoteClicked" Style="{StaticResource PrimaryButtonStyle}" WidthRequest="56" />
          </Grid>
        </Border>

        <Label Text="Фильтры" FontAttributes="Bold" />
        <HorizontalStackLayout Spacing="8">
          <Button x:Name="ActiveNotesButton" Text="Активные" Clicked="OnShowActiveClicked" Style="{StaticResource FilterButtonStyle}" />
          <Button x:Name="DeletedNotesButton" Text="Удаленные" Clicked="OnShowDeletedClicked" Style="{StaticResource FilterButtonStyle}" />
          <Button x:Name="AllNotesButton" Text="Все" Clicked="OnShowAllClicked" Style="{StaticResource FilterButtonStyle}" />
        </HorizontalStackLayout>

        <Label Text="Сортировка" FontAttributes="Bold" />
        <HorizontalStackLayout Spacing="8">
          <Button Text="Новые" Clicked="OnSortNewestClicked" Style="{StaticResource FilterButtonStyle}" />
          <Button Text="Старые" Clicked="OnSortOldestClicked" Style="{StaticResource FilterButtonStyle}" />
          <Button Text="А-Я" Clicked="OnSortTitleClicked" Style="{StaticResource FilterButtonStyle}" />
        </HorizontalStackLayout>

        <CollectionView ItemsSource="{Binding Notes}" SelectionMode="None">
          <CollectionView.ItemTemplate>
            <DataTemplate>
              <Border Margin="0,6" Padding="14">
                <VerticalStackLayout Spacing="8">
                  <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="6">
                    <Label Text="{Binding Title}" FontSize="20" FontAttributes="Bold" />
                    <Button Grid.Column="1" Text="↩" Clicked="OnRestoreNoteClicked" Style="{StaticResource TopIconButtonStyle}" IsVisible="{Binding IsDeleted}"/>
                    <Button Grid.Column="2" Text="🗑" Clicked="OnDeleteClicked" Style="{StaticResource TopIconButtonStyle}" TextColor="{StaticResource DangerColor}" />
                  </Grid>
                  <Label Text="{Binding DeletedBadge}" TextColor="{StaticResource DangerColor}" FontAttributes="Bold" />
                  <Label Text="{Binding Content}" LineBreakMode="WordWrap" Style="{StaticResource MutedLabelStyle}" />
                  <CollectionView ItemsSource="{Binding Checklist}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                      <DataTemplate>
                        <Border Padding="10" Margin="0,3" BackgroundColor="{AppThemeBinding Light={StaticResource LightSoftSurfaceColor}, Dark={StaticResource DarkSoftSurfaceColor}}">
                          <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnChecklistClicked" />
                          </Border.GestureRecognizers>
                          <Label Text="{Binding DisplayText}">
                            <Label.Triggers>
                              <DataTrigger TargetType="Label" Binding="{Binding IsChecked}" Value="True">
                                <Setter Property="TextDecorations" Value="Strikethrough" />
                                <Setter Property="TextColor" Value="{StaticResource SuccessColor}" />
                              </DataTrigger>
                            </Label.Triggers>
                          </Label>
                        </Border>
                      </DataTemplate>
                    </CollectionView.ItemTemplate>
                  </CollectionView>
                  <Label Text="{Binding CreatedAt, StringFormat='Создано: {0:dd.MM.yyyy HH:mm}'}" FontSize="12" Style="{StaticResource MutedLabelStyle}" />
                </VerticalStackLayout>
              </Border>
            </DataTemplate>
          </CollectionView.ItemTemplate>
        </CollectionView>
      </VerticalStackLayout>
    </ScrollView>

    <Grid x:Name="TopMenuOverlay" IsVisible="False" BackgroundColor="{StaticResource OverlayColor}" Padding="18">
      <Border VerticalOptions="Start" HorizontalOptions="End" Padding="14" WidthRequest="250">
        <VerticalStackLayout Spacing="8">
          <Button Text="Удаленные заметки" Clicked="OnMenuDeletedClicked" Style="{StaticResource GhostButtonStyle}" />
          <Button Text="Настройки оформления" Clicked="OnMenuSettingsClicked" Style="{StaticResource GhostButtonStyle}" />
          <Button Text="Закрыть" Clicked="OnCloseMenuClicked" Style="{StaticResource GhostButtonStyle}" />
        </VerticalStackLayout>
      </Border>
    </Grid>

    <Grid x:Name="AddNoteOverlay" IsVisible="False" BackgroundColor="{StaticResource OverlayColor}" Padding="18">
      <Border VerticalOptions="Center" Padding="18">
        <VerticalStackLayout Spacing="12">
          <Grid ColumnDefinitions="*,Auto">
            <Label Text="Новая заметка" FontSize="24" FontAttributes="Bold" />
            <Button Grid.Column="1" Text="✕" Clicked="OnCloseAddNoteClicked" Style="{StaticResource GhostButtonStyle}" />
          </Grid>
          <Entry x:Name="NoteTitleEntry" Placeholder="Заголовок" FontSize="20" />
          <Editor x:Name="NoteContentEditor" Placeholder="Текст заметки" AutoSize="TextChanges" MinimumHeightRequest="150" />
          <Editor x:Name="ChecklistEditor" Placeholder="Чек-лист: каждая строка — отдельный пункт" AutoSize="TextChanges" MinimumHeightRequest="90" />
          <Button Text="Сохранить заметку" Clicked="OnAddNoteClicked" Style="{StaticResource PrimaryButtonStyle}" />
        </VerticalStackLayout>
      </Border>
    </Grid>
  </Grid>
</ContentPage>
