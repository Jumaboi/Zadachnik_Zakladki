<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MyNotesApp.ViewModels"
             x:Class="MyNotesApp.Pages.TasksPage"
             Title="Задачник">
  <ContentPage.BindingContext>
    <vm:TasksViewModel />
  </ContentPage.BindingContext>

  <Grid>
    <ScrollView>
      <VerticalStackLayout Padding="18" Spacing="16">
        <Frame Padding="18">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <VerticalStackLayout Spacing="6">
              <Label Text="Задачник" FontSize="28" FontAttributes="Bold" />
              <Label Text="Добавляйте задачи в отдельном окне. Дата создания ставится автоматически, а срок выполнения можно оставить пустым." Style="{StaticResource MutedLabelStyle}" />
            </VerticalStackLayout>
            <Button Grid.Column="1" Text="＋" FontSize="24" Clicked="OnOpenAddTaskClicked" Style="{StaticResource SecondaryButtonStyle}" WidthRequest="56" />
          </Grid>
        </Frame>

        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*" ColumnSpacing="10" RowSpacing="8">
          <Label Text="Статус" VerticalOptions="Center" Style="{StaticResource MutedLabelStyle}" />
          <Picker x:Name="StatusFilterPicker" Grid.Column="1" SelectedIndexChanged="OnFilterChanged">
            <Picker.Items>
              <x:String>Активные</x:String>
              <x:String>В процессе</x:String>
              <x:String>Отложенные</x:String>
              <x:String>Выполненные</x:String>
              <x:String>Удаленные</x:String>
              <x:String>Все</x:String>
            </Picker.Items>
          </Picker>
          <Label Grid.Row="1" Text="Сортировка" VerticalOptions="Center" Style="{StaticResource MutedLabelStyle}" />
          <Picker x:Name="SortPicker" Grid.Row="1" Grid.Column="1" SelectedIndexChanged="OnFilterChanged">
            <Picker.Items>
              <x:String>Сначала срочные</x:String>
              <x:String>Новые сверху</x:String>
              <x:String>Старые сверху</x:String>
              <x:String>По статусу</x:String>
              <x:String>По заголовку</x:String>
            </Picker.Items>
          </Picker>
        </Grid>

        <CollectionView ItemsSource="{Binding Tasks}" SelectionMode="None">
          <CollectionView.ItemTemplate>
            <DataTemplate>
              <Frame Margin="0,6" Padding="14">
                <VerticalStackLayout Spacing="8">
                  <Grid ColumnDefinitions="*,Auto">
                    <Label Text="{Binding Title}" FontSize="20" FontAttributes="Bold" />
                    <Label Grid.Column="1" Text="{Binding StatusDisplay}" TextColor="{StaticResource AccentColor}" FontAttributes="Bold" />
                  </Grid>
                  <Label Text="{Binding Description}" LineBreakMode="WordWrap" Style="{StaticResource MutedLabelStyle}" />
                  <Label Text="{Binding CreatedAtDisplay}" FontSize="12" Style="{StaticResource MutedLabelStyle}" />
                  <Label Text="{Binding DueDateDisplay}" TextColor="{StaticResource PrimaryColor}" />
                  <Label Text="{Binding ReminderDisplay}" TextColor="{StaticResource SuccessColor}" />
                  <FlexLayout Wrap="Wrap" AlignItems="Center" JustifyContent="Start">
                    <Button Text="В процессе" Clicked="OnSetInProgressClicked" Margin="0,4,6,0" Style="{StaticResource GhostButtonStyle}" />
                    <Button Text="Отложить" Clicked="OnSetDeferredClicked" Margin="0,4,6,0" Style="{StaticResource GhostButtonStyle}" />
                    <Button Text="Выполнено" Clicked="OnSetCompletedClicked" Margin="0,4,6,0" Style="{StaticResource GhostButtonStyle}" />
                    <Button Text="В удаленные" Clicked="OnMoveToDeletedClicked" Margin="0,4,6,0" Style="{StaticResource GhostButtonStyle}" TextColor="{StaticResource DangerColor}" />
                    <Button Text="Удалить навсегда" Clicked="OnDeleteForeverClicked" Margin="0,4,6,0" Style="{StaticResource GhostButtonStyle}" TextColor="{StaticResource DangerColor}" />
                  </FlexLayout>
                </VerticalStackLayout>
              </Frame>
            </DataTemplate>
          </CollectionView.ItemTemplate>
        </CollectionView>
      </VerticalStackLayout>
    </ScrollView>

    <Grid x:Name="AddTaskOverlay" IsVisible="False" BackgroundColor="{StaticResource OverlayColor}" Padding="18">
      <Frame VerticalOptions="Center" Padding="18">
        <VerticalStackLayout Spacing="12">
          <Grid ColumnDefinitions="*,Auto">
            <Label Text="Новая задача" FontSize="24" FontAttributes="Bold" />
            <Button Grid.Column="1" Text="✕" Clicked="OnCloseAddTaskClicked" Style="{StaticResource GhostButtonStyle}" />
          </Grid>
          <Entry x:Name="TaskTitleEntry" Placeholder="Что нужно сделать?" FontSize="20" />
          <Editor x:Name="TaskDescriptionEditor" Placeholder="Описание, детали, ссылки" AutoSize="TextChanges" MinimumHeightRequest="95" />
          <HorizontalStackLayout Spacing="8">
            <CheckBox x:Name="UseDueDateCheckBox" CheckedChanged="OnUseDueDateChanged" />
            <Label Text="Указать срок выполнения" VerticalOptions="Center" />
          </HorizontalStackLayout>
          <Label Text="Можно оставить пустым — дата создания сохранится автоматически." FontSize="12" Style="{StaticResource MutedLabelStyle}" />
          <VerticalStackLayout x:Name="DueDatePanel" IsVisible="False" Spacing="8">
            <DatePicker x:Name="DueDatePicker" />
            <TimePicker x:Name="DueTimePicker" />
            <HorizontalStackLayout Spacing="8">
              <CheckBox x:Name="UseReminderCheckBox" />
              <Label Text="Напомнить в это же время" VerticalOptions="Center" />
            </HorizontalStackLayout>
          </VerticalStackLayout>
          <Button Text="Сохранить задачу" Clicked="OnAddTaskClicked" Style="{StaticResource SecondaryButtonStyle}" />
        </VerticalStackLayout>
      </Frame>
    </Grid>
  </Grid>
</ContentPage>
