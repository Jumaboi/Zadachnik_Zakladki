<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MyNotesApp.ViewModels"
             x:Class="MyNotesApp.Pages.TasksPage"
             Title="Задачник">
  <ContentPage.BindingContext>
    <vm:TasksViewModel />
  </ContentPage.BindingContext>

  <Grid>
    <ScrollView>
      <VerticalStackLayout Padding="18" Spacing="16">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
          <Button Text="‹" Clicked="OnBackClicked" Style="{StaticResource TopIconButtonStyle}" />
          <VerticalStackLayout Grid.Column="1" Spacing="2">
            <Label Text="Задачник" FontSize="28" FontAttributes="Bold" />
            <Label x:Name="TasksModeLabel" Text="Активные задачи" Style="{StaticResource MutedLabelStyle}" />
          </VerticalStackLayout>
          <Button Grid.Column="2" Text="☾" Clicked="OnToggleThemeClicked" Style="{StaticResource TopIconButtonStyle}" />
          <Button Grid.Column="3" Text="⋯" Clicked="OnOpenMenuClicked" Style="{StaticResource TopIconButtonStyle}" />
        </Grid>

        <Border Padding="18">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <Label Text="Дата создания ставится автоматически. Срок выполнения можно оставить пустым и включить только при необходимости." Style="{StaticResource MutedLabelStyle}" />
            <Button Grid.Column="1" Text="＋" FontSize="24" Clicked="OnOpenAddTaskClicked" Style="{StaticResource SecondaryButtonStyle}" WidthRequest="56" />
          </Grid>
        </Border>

        <Label Text="Фильтры" FontAttributes="Bold" />
        <FlexLayout Wrap="Wrap" AlignItems="Center">
          <Button Text="Активные" Clicked="OnFilterActiveClicked" Style="{StaticResource FilterButtonStyle}" Margin="0,0,8,8" />
          <Button Text="В процессе" Clicked="OnFilterInProgressClicked" Style="{StaticResource FilterButtonStyle}" Margin="0,0,8,8" />
          <Button Text="Отложенные" Clicked="OnFilterDeferredClicked" Style="{StaticResource FilterButtonStyle}" Margin="0,0,8,8" />
          <Button Text="Выполненные" Clicked="OnFilterCompletedClicked" Style="{StaticResource FilterButtonStyle}" Margin="0,0,8,8" />
          <Button Text="Удаленные" Clicked="OnFilterDeletedClicked" Style="{StaticResource FilterButtonStyle}" Margin="0,0,8,8" />
          <Button Text="Все" Clicked="OnFilterAllClicked" Style="{StaticResource FilterButtonStyle}" Margin="0,0,8,8" />
        </FlexLayout>

        <Label Text="Сортировка" FontAttributes="Bold" />
        <HorizontalStackLayout Spacing="8">
          <Button Text="Срочные" Clicked="OnSortUrgentClicked" Style="{StaticResource FilterButtonStyle}" />
          <Button Text="Новые" Clicked="OnSortNewestClicked" Style="{StaticResource FilterButtonStyle}" />
          <Button Text="А-Я" Clicked="OnSortTitleClicked" Style="{StaticResource FilterButtonStyle}" />
        </HorizontalStackLayout>

        <CollectionView ItemsSource="{Binding Tasks}" SelectionMode="None">
          <CollectionView.ItemTemplate>
            <DataTemplate>
              <Border Margin="0,6" Padding="14">
                <VerticalStackLayout Spacing="8">
                  <Grid ColumnDefinitions="*,Auto">
                    <Label Text="{Binding Title}" FontSize="20" FontAttributes="Bold" />
                    <Label Grid.Column="1" Text="{Binding StatusDisplay}" TextColor="{StaticResource AccentColor}" FontAttributes="Bold" />
                  </Grid>
                  <Label Text="{Binding Description}" LineBreakMode="WordWrap" Style="{StaticResource MutedLabelStyle}" />
                  <Label Text="{Binding CreatedAtDisplay}" FontSize="12" Style="{StaticResource MutedLabelStyle}" />
                  <Label Text="{Binding DueDateDisplay}" TextColor="{StaticResource AccentColor}" />
                  <Label Text="{Binding ReminderDisplay}" TextColor="{StaticResource SuccessColor}" />
                  <HorizontalStackLayout Spacing="8">
                    <Button Text="▶" Clicked="OnSetInProgressClicked" Style="{StaticResource TopIconButtonStyle}" />
                    <Button Text="⏸" Clicked="OnSetDeferredClicked" Style="{StaticResource TopIconButtonStyle}" />
                    <Button Text="✓" Clicked="OnSetCompletedClicked" Style="{StaticResource TopIconButtonStyle}" TextColor="{StaticResource SuccessColor}" />
                    <Button Text="🗑" Clicked="OnMoveToDeletedClicked" Style="{StaticResource TopIconButtonStyle}" TextColor="{StaticResource DangerColor}" />
                                        <Button Text="✖" Clicked="OnDeleteForeverClicked" Style="{StaticResource TopIconButtonStyle}" TextColor="{StaticResource DangerColor}" IsVisible="{Binding IsDeleted}"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
              </Border>
            </DataTemplate>
          </CollectionView.ItemTemplate>
        </CollectionView>
      </VerticalStackLayout>
    </ScrollView>

    <Grid x:Name="TopMenuOverlay" IsVisible="False" BackgroundColor="{StaticResource OverlayColor}" Padding="18">
      <Border VerticalOptions="Start" HorizontalOptions="End" Padding="14" WidthRequest="250">
        <VerticalStackLayout Spacing="8">
          <Button Text="Удаленные задачи" Clicked="OnMenuDeletedClicked" Style="{StaticResource GhostButtonStyle}" />
          <Button Text="Настройки оформления" Clicked="OnMenuSettingsClicked" Style="{StaticResource GhostButtonStyle}" />
          <Button Text="Закрыть" Clicked="OnCloseMenuClicked" Style="{StaticResource GhostButtonStyle}" />
        </VerticalStackLayout>
      </Border>
    </Grid>

    <Grid x:Name="AddTaskOverlay" IsVisible="False" BackgroundColor="{StaticResource OverlayColor}" Padding="18">
      <Border VerticalOptions="Center" Padding="18">
        <VerticalStackLayout Spacing="12">
          <Grid ColumnDefinitions="*,Auto">
            <Label Text="Новая задача" FontSize="24" FontAttributes="Bold" />
            <Button Grid.Column="1" Text="✕" Clicked="OnCloseAddTaskClicked" Style="{StaticResource GhostButtonStyle}" />
          </Grid>
          <Entry x:Name="TaskTitleEntry" Placeholder="Что нужно сделать?" FontSize="20" />
          <Editor x:Name="TaskDescriptionEditor" Placeholder="Описание, детали, ссылки" AutoSize="TextChanges" MinimumHeightRequest="95" />
          <HorizontalStackLayout Spacing="8">
            <CheckBox x:Name="UseDueDateCheckBox" CheckedChanged="OnUseDueDateChanged" />
            <Label Text="Указать срок выполнения" VerticalOptions="Center" />
          </HorizontalStackLayout>
          <Label Text="Можно оставить пустым — дата создания сохранится автоматически." FontSize="12" Style="{StaticResource MutedLabelStyle}" />
          <VerticalStackLayout x:Name="DueDatePanel" IsVisible="False" Spacing="8">
            <DatePicker x:Name="DueDatePicker" />
            <TimePicker x:Name="DueTimePicker" />
            <HorizontalStackLayout Spacing="8">
              <CheckBox x:Name="UseReminderCheckBox" />
              <Label Text="Напомнить в это же время" VerticalOptions="Center" />
            </HorizontalStackLayout>
          </VerticalStackLayout>
          <Button Text="Сохранить задачу" Clicked="OnAddTaskClicked" Style="{StaticResource SecondaryButtonStyle}" />
        </VerticalStackLayout>
      </Border>
    </Grid>
  </Grid>
</ContentPage>
