<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Colors.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!-- PAGE -->
    <Style TargetType="ContentPage">
        <Setter Property="BackgroundColor">
            <Setter.Value>
                <AppThemeBinding Light="{StaticResource LightBackground}"
                                 Dark="{StaticResource DarkBackground}" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- LABEL -->
    <Style TargetType="Label">
        <Setter Property="TextColor">
            <Setter.Value>
                <AppThemeBinding Light="{StaticResource LightText}"
                                 Dark="{StaticResource DarkText}" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- MUTED LABEL -->
    <Style x:Key="MutedLabelStyle" TargetType="Label">
        <Setter Property="TextColor">
            <Setter.Value>
                <AppThemeBinding Light="{StaticResource LightMutedText}"
                                 Dark="{StaticResource DarkMutedText}" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- BORDER (карточки) -->
    <Style TargetType="Border">
        <Setter Property="BackgroundColor">
            <Setter.Value>
                <AppThemeBinding Light="{StaticResource LightSurface}"
                                 Dark="{StaticResource DarkSurface}" />
            </Setter.Value>
        </Setter>

        <Setter Property="Stroke">
            <Setter.Value>
                <AppThemeBinding Light="{StaticResource LightBorder}"
                                 Dark="{StaticResource DarkBorder}" />
            </Setter.Value>
        </Setter>

        <Setter Property="StrokeThickness" Value="1"/>
        <Setter Property="StrokeShape">
            <RoundRectangle CornerRadius="18"/>
        </Setter>
        <Setter Property="Padding" Value="16"/>
    </Style>

    <!-- PRIMARY BUTTON -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Accent}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="HeightRequest" Value="48" />
    </Style>

    <!-- GHOST BUTTON (ВАЖНО — теперь работает тема) -->
    <Style x:Key="GhostButtonStyle" TargetType="Button">

        <Setter Property="BackgroundColor">
            <Setter.Value>
                <AppThemeBinding Light="Transparent"
                                 Dark="Transparent"/>
            </Setter.Value>
        </Setter>

        <Setter Property="TextColor" Value="{StaticResource Accent}" />

        <Setter Property="BorderColor">
            <Setter.Value>
                <AppThemeBinding Light="{StaticResource LightBorder}"
                                 Dark="{StaticResource DarkBorder}"/>
            </Setter.Value>
        </Setter>

        <Setter Property="BorderWidth" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="12,6"/>

    </Style>

    <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
        <Setter Property="BackgroundColor" Value="{StaticResource SuccessColor}" />
    </Style>

    <Style x:Key="TopIconButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource Accent}" />
        <Setter Property="BorderColor" Value="Transparent" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="WidthRequest" Value="44" />
        <Setter Property="HeightRequest" Value="44" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontSize" Value="18" />
    </Style>

    <Style x:Key="FilterButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
        <Setter Property="HeightRequest" Value="38" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="10,4" />
    </Style>

    <Style TargetType="Picker">
        <Setter Property="TextColor">
            <Setter.Value>
                <AppThemeBinding Light="{StaticResource LightText}" Dark="{StaticResource DarkText}"/>
            </Setter.Value>
        </Setter>
        <Setter Property="BackgroundColor">
            <Setter.Value>
                <AppThemeBinding Light="{StaticResource LightSurface}" Dark="{StaticResource DarkSurface}"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Entry">
        <Setter Property="TextColor"><Setter.Value><AppThemeBinding Light="{StaticResource LightText}" Dark="{StaticResource DarkText}"/></Setter.Value></Setter>
        <Setter Property="PlaceholderColor"><Setter.Value><AppThemeBinding Light="{StaticResource LightMutedText}" Dark="{StaticResource DarkMutedText}"/></Setter.Value></Setter>
    </Style>

    <Style TargetType="Editor">
        <Setter Property="TextColor"><Setter.Value><AppThemeBinding Light="{StaticResource LightText}" Dark="{StaticResource DarkText}"/></Setter.Value></Setter>
        <Setter Property="PlaceholderColor"><Setter.Value><AppThemeBinding Light="{StaticResource LightMutedText}" Dark="{StaticResource DarkMutedText}"/></Setter.Value></Setter>
    </Style>

</ResourceDictionary>