<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- BACKGROUND -->
    <Color x:Key="LightBackground">#F7F8FC</Color>
    <Color x:Key="DarkBackground">#0F172A</Color>

    <!-- SURFACE (карточки) -->
    <Color x:Key="LightSurface">#FFFFFF</Color>
    <Color x:Key="DarkSurface">#1E293B</Color>

    <!-- SOFT SURFACE -->
    <Color x:Key="LightSoftSurface">#EEF2FF</Color>
    <Color x:Key="DarkSoftSurface">#273449</Color>

    <!-- TEXT -->
    <Color x:Key="LightText">#0F172A</Color>
    <Color x:Key="DarkText">#F8FAFC</Color>

    <Color x:Key="LightMutedText">#64748B</Color>
    <Color x:Key="DarkMutedText">#CBD5E1</Color>

    <!-- BORDER -->
    <Color x:Key="LightBorder">#E2E8F0</Color>
    <Color x:Key="DarkBorder">#334155</Color>

    <!-- ACCENT -->
    <Color x:Key="Accent">#6D5DF6</Color>

</ResourceDictionary>